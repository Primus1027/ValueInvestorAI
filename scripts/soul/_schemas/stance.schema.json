{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pairwise equivalence entry (Phase 2 Layer 1)",
  "type": "object",
  "required": ["pair_id", "seed_ids", "equivalent", "confidence"],
  "properties": {
    "pair_id": {"type": "string"},
    "seed_ids": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 2,
      "maxItems": 2
    },
    "equivalent": {"type": "boolean"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "brief_reason": {"type": "string", "maxLength": 200},
    "arbitrated_by_opus": {"type": "boolean"},
    "opus_rationale": {"type": "string"},
    "low_confidence_flag": {"type": "boolean"}
  }
}
