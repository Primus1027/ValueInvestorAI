{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ValueInvestorAI Company Data Contract v1.0",
  "description": "Schema for company_data input to PrinciplesEngine.evaluate(). Contract frozen with Principles/v1.0.md — future MVP yfinance / edgartools / qualitative_resolver adapters must conform to this shape.",
  "type": "object",
  "required": ["company", "financials", "business"],
  "properties": {
    "company": {
      "type": "object",
      "required": ["ticker", "name"],
      "properties": {
        "ticker": {"type": "string", "description": "Stock ticker symbol"},
        "name": {"type": "string"},
        "sector": {"type": "string"},
        "industry": {"type": "string"},
        "revenue_growth_3yr_cagr": {
          "type": "number",
          "description": "Own company's 3-year revenue CAGR (needed by cl_03)"
        },
        "revenue_growth_5yr_cagr": {"type": "number"}
      }
    },
    "financials": {
      "type": "object",
      "description": "Required for quantitative_hard rules (cl_02)",
      "properties": {
        "roe_latest": {"type": "number"},
        "roe_5yr_avg": {"type": "number"},
        "roe_10yr_avg": {"type": "number"},
        "roic_latest": {"type": "number", "description": "Preferred for cl_02 (bypasses leverage inflation)"},
        "roic_5yr_avg": {"type": "number"},
        "roic_10yr_avg": {"type": "number"},
        "debt_to_equity": {"type": "number"},
        "free_cash_flow_positive_years_of_10": {"type": "number"},
        "fcf_to_net_income_5yr_avg": {"type": "number"},
        "ocf_to_net_income_5yr_avg": {"type": "number"},
        "gross_margin": {"type": "number"},
        "net_margin": {"type": "number"},
        "pe_ratio": {"type": "number"},
        "pb_ratio": {"type": "number"},
        "years_of_profitability_in_10": {"type": "number"}
      }
    },
    "competitors": {
      "type": "array",
      "description": "Direct competitors — required for cl_03 moat erosion check",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {"type": "string"},
          "ticker": {"type": "string"},
          "revenue_growth_3yr_cagr": {"type": "number"},
          "market_share_trend": {"type": "string", "enum": ["rising", "stable", "declining"]}
        }
      },
      "minItems": 0
    },
    "business": {
      "type": "object",
      "description": "Qualitative judgments. Populated by Layer 1 LLM Agent or human evaluator, NOT by Agent operating as a master. Each field must carry rationale.",
      "properties": {
        "is_in_circle_of_competence": {
          "type": "object",
          "properties": {
            "value": {"type": "boolean"},
            "evaluator": {"type": "string", "enum": ["llm", "human"]},
            "rationale": {"type": "string"},
            "master_votes": {
              "type": "object",
              "description": "Per-master circle-of-competence vote (2/3 required to be inside circle)",
              "properties": {
                "buffett_methodology_vote": {"type": "boolean"},
                "munger_methodology_vote": {"type": "boolean"},
                "duan_methodology_vote": {"type": "boolean"}
              }
            }
          }
        },
        "is_explainable_in_few_sentences": {
          "type": "object",
          "description": "cl_01 required: can business model be explained in 1-3 sentences to a layperson?",
          "properties": {
            "value": {"type": "boolean"},
            "sentence_count_needed": {"type": "number"},
            "evaluator": {"type": "string", "enum": ["llm", "human"]},
            "rationale": {"type": "string"},
            "explanation_text": {"type": "string"}
          }
        },
        "moat_types_identified": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["brand", "cost_advantage", "network_effect", "switching_cost", "regulatory", "scale", "none_identified"]
          }
        }
      }
    },
    "management": {
      "type": "object",
      "description": "cl_04 required: analysis of management communication quality",
      "properties": {
        "communication_analysis_3yr": {
          "type": "object",
          "properties": {
            "emphasizes_revenue_or_ebitda": {"type": "boolean"},
            "discloses_roic": {"type": "boolean"},
            "discloses_free_cash_flow": {"type": "boolean"},
            "financials_require_heavy_footnotes": {"type": "boolean"},
            "metric_bias_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "0 = balanced disclosure, 1 = pure EBITDA/revenue narrative with full ROIC/FCF avoidance"
            },
            "evaluator": {"type": "string", "enum": ["llm", "human"]},
            "rationale": {"type": "string"}
          }
        },
        "integrity_flags": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "portfolio": {
      "type": "object",
      "description": "For position_sizing rules (currently none HARD — may populate in v1.1+)",
      "properties": {
        "total_holdings_count": {"type": "number"},
        "target_position_pct": {"type": "number", "minimum": 0, "maximum": 1},
        "concentration_top5_pct": {"type": "number"}
      }
    }
  }
}
